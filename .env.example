# OandaFX — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to Git.

# OANDA API (alternative to accounts.yaml)
OANDA_API_KEY_1=your-oanda-api-key-here
OANDA_ACCOUNT_ID_1=001-001-XXXXXXX-001
OANDA_ENVIRONMENT_1=practice

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=-100XXXXXXXXXX

# Email Alerts (optional)
EMAIL_ALERTS_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_RECIPIENT=alerts@your-domain.com

# Dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-secure-password-here
DASHBOARD_PORT=8080

# Google Drive (for Colab training)
GDRIVE_BASE_PATH=/content/drive/MyDrive/oandafx
